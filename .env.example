# Google Sheets
SHEET_ID=1Dz0s7VDTtbC90mXk97-R19bseQYnSPI7d3I3FVgDf0Y

# Вариант A — для локального запуска (путь к JSON-файлу ключа)
GOOGLE_SA_JSON=/path/to/service-account-key.json

# Вариант B — для Docker/relaxdev.ru (содержимое JSON одной строкой, без переносов)
# GOOGLE_SA_JSON_CONTENT={"type":"service_account","project_id":"...","private_key":"..."}

# Telegram-алерты (существующий бот на relaxdev.ru)
TELEGRAM_TOKEN=123456789:AABBccDDee...
TELEGRAM_CHAT_ID=-100123456789

# Регион WB (dest для Москвы, менять не нужно если регион не меняется)
# DEST= — не используется напрямую, значение захардкожено в config.py
# Переопределить можно, добавив чтение os.getenv("DEST") в config.py
